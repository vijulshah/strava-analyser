# Strava API Credentials
# Get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# Obtain via scripts/get_refresh_token.py
# Required scopes: activity:read_all,profile:read_all,read_all
STRAVA_REFRESH_TOKEN=your_refresh_token_here

# These are managed automatically by the token manager (do not edit manually)
STRAVA_ACCESS_TOKEN=
STRAVA_TOKEN_EXPIRY=0

# FastAPI settings
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=true
